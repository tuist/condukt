<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {% set pageTitle = title and (title + " · " + site.name) or (site.name + " · " + site.tagline) %}
    {% set pageDesc = description or site.description %}
    {% set pageUrl = site.url + page.url %}
    {% set pageSocialImage = socialImage or (site.url + "/assets/social-card.png") %}
    {% set pageSocialImageAlt = socialImageAlt or (site.name + ": " + site.tagline) %}
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDesc }}" />
    <meta name="author" content="Tuist" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="{{ site.themeColor }}" />
    <link rel="canonical" href="{{ pageUrl }}" />
    <link rel="alternate" type="application/atom+xml" href="https://github.com/tuist/condukt/releases.atom" title="Condukt releases" />
    <link rel="alternate" type="application/atom+xml" href="/blog/feed.xml" title="Condukt blog (Atom)" />
    <link rel="alternate" type="application/rss+xml" href="/blog/rss.xml" title="Condukt blog (RSS)" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:locale" content="{{ site.locale }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDesc }}" />
    <meta property="og:url" content="{{ pageUrl }}" />
    <meta property="og:image" content="{{ pageSocialImage }}" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ pageSocialImageAlt }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="{{ site.twitter }}" />
    <meta name="twitter:creator" content="{{ site.twitter }}" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDesc }}" />
    <meta name="twitter:image" content="{{ pageSocialImage }}" />
    <meta name="twitter:image:alt" content="{{ pageSocialImageAlt }}" />

    <link rel="stylesheet" href="/assets/styles.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      "name": "{{ site.name }}",
      "description": "{{ site.description }}",
      "url": "{{ site.url }}",
      "codeRepository": "{{ site.repo }}",
      "programmingLanguage": "Elixir",
      "license": "https://opensource.org/licenses/MIT",
      "author": {
        "@type": "Organization",
        "name": "Tuist",
        "url": "https://tuist.dev"
      },
      "image": "{{ pageSocialImage }}"
    }
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">
          <svg class="brand-mark" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="16" y="16" width="224" height="224" rx="52" fill="#0a0a0b" stroke="#9d7ce0" stroke-width="10"/>
            <polyline points="74,84 124,128 74,172" stroke="#9d7ce0" stroke-width="22" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="132" y="156" width="54" height="20" rx="6" fill="#9d7ce0"/>
          </svg>
          <span class="brand-name">condukt</span><span class="cursor" aria-hidden="true"></span>
        </a>
        <nav class="site-nav">
          <a href="/#features">Features</a>
          <a href="/#install">Install</a>
          <a href="/blog/">Blog</a>
          <a href="{{ site.docs }}">Docs</a>
          <a href="{{ site.repo }}">GitHub</a>
        </nav>
      </div>
    </header>

    <main>{{ content | safe }}</main>

    <footer class="site-footer">
      <div class="container">
        <p>{{ site.tagline }} · MIT licensed · <a href="{{ site.repo }}">github.com/tuist/condukt</a> · Made by the <a href="https://tuist.dev">Tuist</a> team.</p>
      </div>
    </footer>
  </body>
</html>
