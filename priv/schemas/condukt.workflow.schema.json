{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tuist/condukt/main/priv/schemas/condukt.workflow.schema.json",
  "title": "Condukt Workflow",
  "description": "A Condukt workflow document: a typed DAG of steps with inputs, references between steps via ${...} expressions, and an optional top-level output.",
  "type": "object",
  "required": ["steps"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional pointer to this schema. Editors use it for completion and validation."
    },
    "name": {
      "type": "string",
      "description": "Workflow name. Defaults to the file basename if omitted.",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "inputs": {
      "type": "object",
      "description": "Map of input id to a JSON-Schema-like type fragment.",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "enum": ["string", "integer", "number", "boolean", "array", "object"]
          },
          "description": { "type": "string" },
          "default": {},
          "enum": { "type": "array" },
          "items": { "type": "object" }
        }
      }
    },
    "runtime": {
      "type": "object",
      "description": "Workflow-level runtime defaults. Library options passed to Condukt.Workflows.run/3 override these values.",
      "additionalProperties": false,
      "properties": {
        "model": {
          "oneOf": [{ "type": "string" }, { "type": "object" }],
          "description": "Default ReqLLM model spec for agent steps that do not declare their own model."
        },
        "sandbox": {
          "enum": ["local", "virtual"],
          "description": "Default sandbox backend for command and tool execution."
        },
        "cwd": {
          "type": "string",
          "description": "Default working directory for command steps, tools, and sandbox initialization."
        }
      }
    },
    "steps": {
      "type": "object",
      "description": "Map of step id to step definition. Step ids must match ^[a-zA-Z_][a-zA-Z0-9_]*$.",
      "minProperties": 1,
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/$defs/step" }
      },
      "additionalProperties": false
    },
    "output": {
      "description": "Top-level output expression. Evaluated after the run completes; printed by `condukt run`."
    }
  },
  "$defs": {
    "expression": {
      "type": "string",
      "description": "A string containing zero or more ${...} expression placeholders. A field that is exactly one ${expr} preserves the underlying value's type."
    },
    "stepId": {
      "type": "string",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
    },
    "needs": {
      "type": "array",
      "items": { "$ref": "#/$defs/stepId" },
      "uniqueItems": true
    },
    "step": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["cmd", "agent", "http", "tool", "map"]
        },
        "needs": { "$ref": "#/$defs/needs" },
        "when": { "$ref": "#/$defs/expression" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "cmd" } } },
          "then": { "$ref": "#/$defs/cmdStep" }
        },
        {
          "if": { "properties": { "kind": { "const": "agent" } } },
          "then": { "$ref": "#/$defs/agentStep" }
        },
        {
          "if": { "properties": { "kind": { "const": "http" } } },
          "then": { "$ref": "#/$defs/httpStep" }
        },
        {
          "if": { "properties": { "kind": { "const": "tool" } } },
          "then": { "$ref": "#/$defs/toolStep" }
        },
        {
          "if": { "properties": { "kind": { "const": "map" } } },
          "then": { "$ref": "#/$defs/mapStep" }
        }
      ]
    },
    "cmdStep": {
      "type": "object",
      "required": ["argv"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "cmd" },
        "needs": { "$ref": "#/$defs/needs" },
        "when": { "$ref": "#/$defs/expression" },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "cwd": { "type": "string" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "agentStep": {
      "type": "object",
      "required": ["input"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "agent" },
        "needs": { "$ref": "#/$defs/needs" },
        "when": { "$ref": "#/$defs/expression" },
        "model": { "type": "string" },
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "input": {},
        "system": { "type": "string" },
        "output_schema": { "type": "object" }
      }
    },
    "httpStep": {
      "type": "object",
      "required": ["method", "url"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "http" },
        "needs": { "$ref": "#/$defs/needs" },
        "when": { "$ref": "#/$defs/expression" },
        "method": {
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
        },
        "url": { "type": "string" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": {},
        "expect_status": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" } }
          ]
        }
      }
    },
    "toolStep": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "tool" },
        "needs": { "$ref": "#/$defs/needs" },
        "when": { "$ref": "#/$defs/expression" },
        "id": { "type": "string" },
        "args": { "type": "object" }
      }
    },
    "mapStep": {
      "type": "object",
      "required": ["over", "as", "do"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "map" },
        "needs": { "$ref": "#/$defs/needs" },
        "when": { "$ref": "#/$defs/expression" },
        "over": { "$ref": "#/$defs/expression" },
        "as": { "$ref": "#/$defs/stepId" },
        "do": { "$ref": "#/$defs/step" },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
